<h5 class="mb-3">{{ title }}</h5>

{{ form_start(form, {attr: {class: 'plan-form'}}) }}
    <div class="form-group">
        {{ form_label(form.nombrePlan) }}
        {{ form_widget(form.nombrePlan, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.nombrePlan) }}
    </div>
    <div class="form-group">
        {{ form_label(form.costo) }}
        {{ form_widget(form.costo, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.costo) }}
    </div>
    <div class="form-group">
        {{ form_label(form.duracionDias) }}
        {{ form_widget(form.duracionDias, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.duracionDias) }}
    </div>
    <div class="form-group form-check">
        {{ form_widget(form.estado, {attr: {class: 'form-check-input'}}) }}
        {{ form_label(form.estado, null, {label_attr: {class: 'form-check-label'}}) }}
        {{ form_errors(form.estado) }}
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">{{ action }}</button>
    </div>
{{ form_end(form) }}