{% extends 'layouts/admin.html.twig' %}

{% block title %}Gestión de Planes - FitLife{% endblock %}

{% block page_title %}Gestión de Planes de Membresía{% endblock %}

{% block content %}
<div class="stats-row">
  <div class="stat-card c1">
    <div class="stat-icon">📋</div>
    <div class="stat-val">{{ stats.total }}</div>
    <div class="stat-lbl">Total planes</div>
  </div>
  <div class="stat-card c2">
    <div class="stat-icon">✅</div>
    <div class="stat-val">{{ stats.activos }}</div>
    <div class="stat-lbl">Activos</div>
  </div>
  <div class="stat-card c3">
    <div class="stat-icon">⛔</div>
    <div class="stat-val">{{ stats.inactivos }}</div>
    <div class="stat-lbl">Inactivos</div>
  </div>
  <div class="stat-card c4">
    <div class="stat-icon">💰</div>
    <div class="stat-val">Bs</div>
    <div class="stat-lbl">Precio promedio</div>
  </div>
</div>

<div class="toolbar">
  <div class="search-wrapper">
    <i class="fas fa-search search-icon"></i>
    <input type="text" id="searchInput" class="form-control search-input" placeholder="Buscar plan...">
  </div>
  <a href="{{ path('admin_planes_new') }}" class="btn-new">
    <i class="fas fa-plus"></i> Nuevo Plan
  </a>
</div>

<div class="table-container">
  <table class="personal-table">
    <thead>
      <tr>
        <th>#</th>
        <th>NOMBRE</th>
        <th>COSTO (Bs)</th>
        <th>DURACIÓN (días)</th>
        <th>CLASES</th>
        <th>ESTADO</th>
        <th>ACCIONES</th>
      </tr>
    </thead>
    <tbody>
      {% for plan in planes %}
      <tr>
        <td>{{ plan.id }}</td>
        <td>{{ plan.nombrePlan }}</td>
        <td>{{ plan.costo|number_format(2, ',', '.') }}</td>
        <td>{{ plan.duracionDias }}</td>
        <td>
          {% if plan.incluyeClases %}
            <span class="status-badge active">Incluye</span>
          {% else %}
            <span class="status-badge inactive">No incluye</span>
          {% endif %}
        </td>
        <td>
          {% if plan.estado %}
            <span class="status-badge active">Activo</span>
          {% else %}
            <span class="status-badge inactive">Inactivo</span>
          {% endif %}
        </td>
        <td class="actions">
          <a href="{{ path('admin_planes_edit', {id: plan.id}) }}" class="btn-icon edit">✏️ Editar</a>
          <form method="post" action="{{ path('admin_planes_delete', {'id': plan.id}) }}" style="display:inline-block" onsubmit="return confirm('¿Eliminar este plan?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
            <button class="btn-icon delete" type="submit">🗑️ Eliminar</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr>
        <td colspan="6" class="text-center">No hay planes registrados</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if totalPages > 1 %}
<div class="pagination-container">
  <div class="pagination">
    <a href="{{ currentPage > 1 ? path('admin_planes_index', {page: currentPage-1}) : '#' }}" class="page-link {{ currentPage == 1 ? 'disabled' : '' }}">← Anterior</a>
    {% for i in 1..totalPages %}
      <a href="{{ path('admin_planes_index', {page: i}) }}" class="page-link {{ currentPage == i ? 'active' : '' }}">{{ i }}</a>
    {% endfor %}
    <a href="{{ currentPage < totalPages ? path('admin_planes_index', {page: currentPage+1}) : '#' }}" class="page-link {{ currentPage == totalPages ? 'disabled' : '' }}">Siguiente →</a>
  </div>
</div>
{% endif %}

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const tableRows = document.querySelectorAll('.personal-table tbody tr');
    searchInput.addEventListener('keyup', function() {
        const term = this.value.toLowerCase();
        tableRows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(term) ? '' : 'none';
        });
    });
});
</script>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Mismos estilos que en personal/index, se reutilizan */
:root { --bg: #1e1e2f; --card: #2a2a3a; --border: #3a3a4a; --text: #f0f0f0; --muted: #aaa; --accent: #ffb347; }
.stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 28px; }
.stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 20px; position: relative; overflow: hidden; transition: transform .2s; }
.stat-card:hover { transform: translateY(-2px); }
.stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
.stat-card.c1::before { background: var(--accent); }
.stat-card.c2::before { background: #58a6ff; }
.stat-card.c3::before { background: #3fb950; }
.stat-card.c4::before { background: #bc8cff; }
.stat-icon { font-size: 24px; margin-bottom: 10px; }
.stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 38px; line-height: 1; margin-bottom: 4px; }
.stat-card.c1 .stat-val { color: var(--accent); }
.stat-card.c2 .stat-val { color: #58a6ff; }
.stat-card.c3 .stat-val { color: #3fb950; }
.stat-card.c4 .stat-val { color: #bc8cff; }
.stat-lbl { font-size: 12px; color: var(--muted); }
.toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 20px; }
.search-wrapper { position: relative; flex: 1; max-width: 320px; }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 14px; }
.search-input { padding-left: 36px; background-color: var(--bg); border: 1px solid var(--border); border-radius: 8px; height: 40px; color: var(--text); width: 100%; }
.search-input:focus { border-color: var(--accent); outline: none; }
.btn-new { background-color: var(--accent); border: none; border-radius: 8px; padding: 0 20px; height: 40px; font-weight: 600; color: #000; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
.btn-new:hover { background-color: #e59400; transform: translateY(-1px); color: #000; }
.table-container { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow-x: auto; margin-bottom: 24px; }
.personal-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.personal-table th { text-align: left; padding: 14px 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); border-bottom: 1px solid var(--border); }
.personal-table td { padding: 12px; border-bottom: 1px solid var(--border); color: var(--text); }
.status-badge { display: inline-block; padding: 4px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; background: rgba(255,255,255,0.1); }
.status-badge.active { background: rgba(63, 185, 80, 0.2); color: #3fb950; }
.status-badge.inactive { background: rgba(220, 53, 69, 0.2); color: #dc3545; }
.actions { display: flex; gap: 8px; flex-wrap: wrap; }
.btn-icon { background: none; border: none; color: var(--accent); cursor: pointer; padding: 4px 8px; border-radius: 6px; font-size: 12px; transition: background 0.2s; text-decoration: none; display: inline-block; }
.btn-icon.edit:hover { background: rgba(255, 179, 71, 0.1); }
.btn-icon.delete { color: #dc3545; }
.btn-icon.delete:hover { background: rgba(220, 53, 69, 0.1); }
.pagination-container { display: flex; justify-content: center; margin-top: 20px; }
.pagination { display: flex; gap: 6px; }
.page-link { background: var(--card); border: 1px solid var(--border); padding: 6px 12px; border-radius: 6px; color: var(--text); text-decoration: none; transition: all 0.2s; }
.page-link.active { background: var(--accent); border-color: var(--accent); color: #000; }
.page-link.disabled { opacity: 0.5; pointer-events: none; }
.page-link:hover:not(.disabled) { border-color: var(--accent); background: rgba(255, 179, 71, 0.1); }
</style>
{% endblock %}