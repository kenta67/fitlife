<h5 class="mb-3">{{ title }}</h5>

{{ form_start(form, {attr: {class: 'clase-form'}}) }}
    <div class="form-group">
        {{ form_label(form.nombre) }}
        {{ form_widget(form.nombre, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.nombre) }}
    </div>
    <div class="form-group">
        {{ form_label(form.descripcion) }}
        {{ form_widget(form.descripcion, {attr: {class: 'form-control', rows: 3}}) }}
        {{ form_errors(form.descripcion) }}
    </div>
    <div class="form-group">
        {{ form_label(form.capacidadMax) }}
        {{ form_widget(form.capacidadMax, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.capacidadMax) }}
    </div>
    <div class="form-group">
        {{ form_label(form.horario) }}
        {{ form_widget(form.horario, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.horario) }}
    </div>
    <div class="form-group">
        {{ form_label(form.instructor) }}
        {{ form_widget(form.instructor, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.instructor) }}
    </div>
    <div class="form-group form-check">
        {{ form_widget(form.estado, {attr: {class: 'form-check-input'}}) }}
        {{ form_label(form.estado, null, {label_attr: {class: 'form-check-label'}}) }}
        {{ form_errors(form.estado) }}
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">{{ action }}</button>
    </div>
{{ form_end(form) }}