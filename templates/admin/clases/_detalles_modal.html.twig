<h5 class="mb-3">Detalles de la Clase</h5>

<div class="detalles-info">
    <p><strong>Nombre:</strong> {{ clase.nombre }}</p>
    <p><strong>Instructor:</strong> {{ clase.instructor.nombre }}</p>
    <p><strong>Capacidad máxima:</strong> {{ clase.capacidadMax }}</p>
    <p><strong>Horario:</strong> {{ clase.horario }}</p>
    <p><strong>Descripción:</strong> {{ clase.descripcion ?: 'Sin descripción' }}</p>
    <p><strong>Estado:</strong> {{ clase.estado ? 'Activa' : 'Inactiva' }}</p>
</div>

<h5 class="mb-3">Clientes inscritos ({{ clientes|length }})</h5>

{% if clientes|length > 0 %}
    <table class="clientes-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre completo</th>
                <th>Cédula</th>
                <th>Teléfono</th>
                <th>Correo</th>
            </tr>
        </thead>
        <tbody>
            {% for cliente in clientes %}
            <tr>
                <td>{{ cliente.id }}</td>
                <td>{{ cliente.nombre }} {{ cliente.apellido }}</td>
                <td>{{ cliente.cedula }}</td>
                <td>{{ cliente.telefono ?: '-' }}</td>
                <td>{{ cliente.correo ?: '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="text-muted">No hay clientes inscritos en esta clase.</p>
{% endif %}

<div class="modal-footer px-0 pb-0">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
</div>