{% extends 'layouts/admin.html.twig' %}

{% block title %}Admin — FitLife{% endblock %}

{% block page_title %}Bienvenido, {{ usuario.nombre }}{% endblock %}

{% block content %}
<div class="stats-row">
  <div class="stat-card c1">
    <div class="stat-icon">👤</div>
    <div class="stat-val">{{ stats.clientes }}</div>
    <div class="stat-lbl">Clientes activos</div>
  </div>
  <div class="stat-card c2">
    <div class="stat-icon">🏷️</div>
    <div class="stat-val">{{ stats.membresias }}</div>
    <div class="stat-lbl">Membresías vigentes</div>
  </div>
  <div class="stat-card c3">
    <div class="stat-icon">💰</div>
    <div class="stat-val">{{ stats.ingresos }} bs</div>
    <div class="stat-lbl">Ingresos este mes</div>
  </div>
  <div class="stat-card c4">
    <div class="stat-icon">👨‍💼</div>
    <div class="stat-val">{{ stats.personal }}</div>
    <div class="stat-lbl">Personal registrado</div>
  </div>
</div>

<div class="modules-title">RESUMEN DE CLIENTES Y SUS MEMBRESIAS</div>

<table class="resumen-clientes-table resumen-clientes-table-wrapper">
  <thead>
    <tr>
      <th>Cliente</th>
      <th>Carnet</th>
      <th>Fecha Inicio</th>
      <th>Fecha Fin</th>
      <th>Membresía</th>
      <th>Clase Inscrita</th>
    </tr>
  </thead>
  <tbody>
    {% for resumen in resumen_clientes %}
      <tr>
        <td>{{ resumen.cliente }}</td>
        <td>{{ resumen.carnet }}</td>
        <td>{{ resumen.fecha_inicio }}</td>
        <td>{{ resumen.fecha_fin }}</td>
        <td>{{ resumen.membresia }}</td>
        <td>{{ resumen.clase }}</td>
      </tr>
    {% else %}
      <tr>
        <td colspan="6" style="text-align:center;color:var(--muted)">No hay datos para mostrar.</td>
      </tr>
    {% endfor %}
  </tbody>
  </table>

{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* --- Dashboard cards --- */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.stat-card{
  background:var(--card);border:1px solid var(--border);border-radius:10px;
  padding:20px;position:relative;overflow:hidden;transition:transform .2s;
}
.stat-card:hover{transform:translateY(-2px)}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat-card.c1::before{background:var(--accent)}
.stat-card.c2::before{background:#58a6ff}
.stat-card.c3::before{background:#3fb950}
.stat-card.c4::before{background:#bc8cff}
.stat-icon{font-size:24px;margin-bottom:10px}
.stat-val{font-family:'Bebas Neue',sans-serif;font-size:38px;line-height:1;margin-bottom:4px}
.stat-card.c1 .stat-val{color:var(--accent)}
.stat-card.c2 .stat-val{color:#58a6ff}
.stat-card.c3 .stat-val{color:#3fb950}
.stat-card.c4 .stat-val{color:#bc8cff}
.stat-lbl{font-size:12px;color:var(--muted)}
.modules-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 1px;
  margin-bottom: 14px;
  color: var(--text);
}

/* --- Tabla resumen clientes estilo moderno --- */
.resumen-clientes-table-wrapper {
  background: #181c23;
  border-radius: 14px;
  box-shadow: 0 2px 8px #0002;
  padding: 0;
  margin-bottom: 32px;
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 16px;
  overflow: hidden;
}
.resumen-clientes-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  background: transparent;
  font-size: 16px;
}
.resumen-clientes-table thead tr {
  background: #232837;
}
.resumen-clientes-table th {
  color: #fff;
  font-weight: 600;
  padding: 12px 8px;
  border-bottom: 2px solid #31374a;
  text-align: left;
}
.resumen-clientes-table tbody tr {
  background: #15171d;
  border-radius: 8px;
  transition: background 0.2s;
}
.resumen-clientes-table tbody tr:hover {
  background: #282d3c;
}
.resumen-clientes-table td {
  color: #e6e6e6;
  padding: 10px 8px;
  border-bottom: 1px solid #232837;
}
.resumen-clientes-table tbody tr:last-child td {
  border-bottom: none;
}
.resumen-clientes-table td, .resumen-clientes-table th {
  vertical-align: middle;
}
.resumen-clientes-table th, .resumen-clientes-table td {
  white-space: nowrap;
}
</style>
{% endblock %}