{% extends 'layouts/admin.html.twig' %}

{% block title %}Asignar Membresía a Cliente{% endblock %}

{% block page_title %}Registrar Membresía{% endblock %}

{% block content %}
<div class="form-container" style="max-width: 600px; margin: 0 auto; background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem;">
    {{ form_start(form, {attr: {class: 'membresia-form'}}) }}
        <div class="form-group">
            {{ form_label(form.cliente) }}
            {{ form_widget(form.cliente, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.cliente) }}
        </div>
        <div class="form-group">
            {{ form_label(form.plan) }}
            {{ form_widget(form.plan, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.plan) }}
        </div>
        <div class="form-group">
            {{ form_label(form.fechaInicio) }}
            {{ form_widget(form.fechaInicio, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.fechaInicio) }}
        </div>
        <div class="form-group">
            {{ form_label(form.fechaVencimiento) }}
            {{ form_widget(form.fechaVencimiento, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.fechaVencimiento) }}
        </div>

        <div class="form-buttons" style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2rem;">
            <a href="{{ path('admin_cliente_index') }}" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">Asignar Membresía</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Obtener duraciones de los planes desde los options
document.addEventListener('DOMContentLoaded', function() {
    // Encuentra los selects y campos
    const planSelect = document.querySelector('select[name$="[plan]"]');
    const fechaInicioInput = document.querySelector('input[name$="[fechaInicio]"]');
    const fechaVencimientoInput = document.querySelector('input[name$="[fechaVencimiento]"]');

    // Construir un mapa de id de plan a duración usando los data attributes
    let planDuraciones = {};
    for (const option of planSelect.options) {
        // Symfony muestra el id como value, pero necesitamos la duración
        // Para esto, agregamos un data-duracion en el controlador/formType
        if (option.dataset.duracion) {
            planDuraciones[option.value] = parseInt(option.dataset.duracion);
        }
    }

    function calcularFechaFin() {
        const planId = planSelect.value;
        const duracion = planDuraciones[planId];
        const fechaInicio = fechaInicioInput.value;
        if (duracion && fechaInicio) {
            const fecha = new Date(fechaInicio);
            fecha.setDate(fecha.getDate() + duracion);
            // Formatear yyyy-mm-dd
            const yyyy = fecha.getFullYear();
            const mm = String(fecha.getMonth() + 1).padStart(2, '0');
            const dd = String(fecha.getDate()).padStart(2, '0');
            fechaVencimientoInput.value = `${yyyy}-${mm}-${dd}`;
        } else {
            fechaVencimientoInput.value = '';
        }
    }

    planSelect.addEventListener('change', calcularFechaFin);
    fechaInicioInput.addEventListener('change', calcularFechaFin);
});
</script>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.form-container .form-group { margin-bottom: 1rem; }
.form-container label { display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 500; color: var(--muted); }
.form-container input[type="text"],
.form-container input[type="email"],
.form-container input[type="tel"],
.form-container input[type="date"],
.form-container select,
.form-container textarea { width: 100%; padding: 0.5rem 0.75rem; background-color: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); transition: border-color 0.2s; }
.form-container input:focus,
.form-container select:focus,
.form-container textarea:focus { border-color: var(--accent); outline: none; }
.btn-primary { background-color: var(--accent); border: none; padding: 0.5rem 1rem; border-radius: 8px; color: #000; font-weight: 600; text-decoration: none; display: inline-block; }
.btn-primary:hover { background-color: #e59400; color: #000; }
.btn-secondary { background-color: #2c2c2c; border: 1px solid #444; color: #e0e0e0; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; display: inline-block; }
.btn-secondary:hover { background-color: #3c3c3c; color: #fff; }
</style>
{% endblock %}
