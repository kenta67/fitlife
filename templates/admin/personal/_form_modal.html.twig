<h5 class="mb-3">{{ title }}</h5>

{{ form_start(form, {attr: {class: 'personal-form'}}) }}
    <div class="form-group">
        {{ form_label(form.nombre) }}
        {{ form_widget(form.nombre, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.nombre) }}
    </div>
    <div class="form-group">
        {{ form_label(form.usuario) }}
        {{ form_widget(form.usuario, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.usuario) }}
    </div>
    <div class="form-group">
        {{ form_label(form.contrasena) }}
        {{ form_widget(form.contrasena, {attr: {class: 'form-control'}, required: action == 'Crear'}) }}
        {{ form_errors(form.contrasena) }}
    </div>
    <div class="form-group">
        {{ form_label(form.rol) }}
        {{ form_widget(form.rol, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.rol) }}
    </div>
    <div class="form-group form-check">
        {{ form_widget(form.estado, {attr: {class: 'form-check-input'}}) }}
        {{ form_label(form.estado, null, {label_attr: {class: 'form-check-label'}}) }}
        {{ form_errors(form.estado) }}
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">{{ action }}</button>
    </div>
{{ form_end(form) }}