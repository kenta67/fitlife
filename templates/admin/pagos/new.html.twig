{% extends 'layouts/admin.html.twig' %}

{% block title %}Registrar Pago - FitLife{% endblock %}

{% block page_title %}Registrar Pago{% endblock %}

{% block content %}
<div class="form-container" style="max-width: 600px; margin: 0 auto; background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem;">
    {{ form_start(form, {attr: {class: 'pago-form'}}) }}
        <div class="form-group">
            {{ form_label(form.membresiaCliente) }}
            {{ form_widget(form.membresiaCliente, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.membresiaCliente) }}
        </div>
        <div class="form-group">
            {{ form_label(form.personal) }}
            {{ form_widget(form.personal, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.personal) }}
        </div>
        <div class="form-group">
            {{ form_label(form.monto) }}
            {{ form_widget(form.monto, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.monto) }}
        </div>
        <div class="form-group">
            {{ form_label(form.fechaPago) }}
            {{ form_widget(form.fechaPago, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.fechaPago) }}
        </div>
        <div class="form-group">
            {{ form_label(form.metodoPago) }}
            {{ form_widget(form.metodoPago, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.metodoPago) }}
        </div>
        <div class="form-buttons" style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2rem;">
            <a href="{{ path('admin_pagos_index') }}" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">{{ action }}</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.form-container .form-group { margin-bottom: 1rem; }
.form-container label { display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 500; color: var(--muted); }
.form-container input[type="text"],
.form-container input[type="email"],
.form-container input[type="tel"],
.form-container select,
.form-container textarea { width: 100%; padding: 0.5rem 0.75rem; background-color: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); transition: border-color 0.2s; }
.form-container input:focus,
.form-container select:focus,
.form-container textarea:focus { border-color: var(--accent); outline: none; }
.btn-primary { background-color: var(--accent); border: none; padding: 0.5rem 1rem; border-radius: 8px; color: #000; font-weight: 600; text-decoration: none; display: inline-block; }
.btn-primary:hover { background-color: #e59400; color: #000; }
.btn-secondary { background-color: #2c2c2c; border: 1px solid #444; color: #e0e0e0; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; display: inline-block; }
.btn-secondary:hover { background-color: #3c3c3c; color: #fff; }
</style>
{% endblock %}
