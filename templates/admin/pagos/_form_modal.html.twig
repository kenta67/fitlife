<h5 class="mb-3">{{ title }}</h5>

<div class="modal-form-card">
{{ form_start(form, {attr: {class: 'pago-form'}}) }}
    <div class="form-group">
        {{ form_label(form.membresiaCliente) }}
        {{ form_widget(form.membresiaCliente, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.membresiaCliente) }}
    </div>
    <div class="form-group">
        {{ form_label(form.personal) }}
        {{ form_widget(form.personal, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.personal) }}
    </div>
    <div class="form-group">
        {{ form_label(form.monto) }}
        {{ form_widget(form.monto, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.monto) }}
    </div>
    <div class="form-group">
        {{ form_label(form.fechaPago) }}
        {{ form_widget(form.fechaPago, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.fechaPago) }}
    </div>
    <div class="form-group">
        {{ form_label(form.metodoPago) }}
        {{ form_widget(form.metodoPago, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.metodoPago) }}
    </div>
    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">{{ action }}</button>
    </div>
{{ form_end(form) }}
</div>

{% block stylesheets %}
<style>
.modal-form-card {
    background: var(--card);
    border-radius: 10px;
    padding: 28px 24px 18px 24px;
    box-shadow: 0 2px 16px 0 #0002;
    margin-bottom: 0;
}
.form-group {
    margin-bottom: 18px;
}
.form-control {
    background: #232334;
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 10px 12px;
    font-size: 1rem;
    width: 100%;
    margin-top: 4px;
}
.form-control:focus {
    border-color: var(--accent);
    outline: none;
    box-shadow: 0 0 0 2px #ffb34733;
}
.btn-primary {
    background: var(--accent);
    color: #222;
    border: none;
    padding: 8px 18px;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s;
}
.btn-primary:hover {
    background: #ff9800;
}
.btn-secondary {
    background: #232334;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px 18px;
    margin-right: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s, color .2s;
}
.btn-secondary:hover {
    background: #181828;
    color: var(--accent);
}
</style>
{% endblock %}
