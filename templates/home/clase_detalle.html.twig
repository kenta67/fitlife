{# templates/home/clase_detalle.html.twig — Detalle de clase (dinámico) #}
{% extends 'layouts/public.html.twig' %}

{% block title %}{{ clase.nombre }} — FitLife Gym{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ── HERO CON GRADIENTE ÚNICO POR CLASE ── */
.clase-hero {
  background: {{ clase.gradiente }};
  min-height: 400px;
}

.clase-hero-icon {
  width: 120px;
  height: 120px;
  background: var(--accent);
  color: #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56px;
  margin-bottom: 24px;
  box-shadow: 0 0 60px rgba(255,234,0,.2);
}
.clase-hero-meta {
  display: flex;
  gap: 20px;
  margin-top: 16px;
  flex-wrap: wrap;
}
.clase-hero-meta span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.1);
  padding: 8px 16px;
  border-radius: 50px;
  font-size: 14px;
  color: rgba(255,255,255,.8);
}

/* ── CONTENIDO ── */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 28px;
  margin-top: 48px;
}
.info-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 32px 28px;
  transition: all 0.3s ease;
}
.info-card:hover {
  transform: translateY(-5px);
  border-color: rgba(255,234,0,.2);
  box-shadow: 0 16px 36px rgba(0,0,0,.3);
}
.info-card .card-icon {
  width: 50px;
  height: 50px;
  background: rgba(255,234,0,.1);
  border: 1px solid rgba(255,234,0,.15);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-bottom: 20px;
}
.info-card h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 1px;
  margin-bottom: 14px;
  text-transform: uppercase;
}
.info-card p {
  color: var(--muted);
  font-size: 15px;
  line-height: 1.7;
}

/* ── OTRAS CLASES ── */
.otras-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
  margin-top: 36px;
}
.otra-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px 20px;
  text-decoration: none;
  color: var(--text);
  transition: all 0.3s ease;
}
.otra-card:hover {
  border-color: rgba(255,234,0,.3);
  transform: translateY(-3px);
  box-shadow: 0 10px 24px rgba(0,0,0,.25);
}
.otra-card .mini-icon {
  font-size: 28px;
  flex-shrink: 0;
}
.otra-card .info .name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
}
.otra-card .info .horario {
  font-size: 12px;
  color: var(--muted);
}

/* ── CTA INFERIOR ── */
.clase-cta {
  text-align: center;
  padding: 64px 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 24px;
  margin-top: 60px;
}
.clase-cta h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(32px, 4vw, 48px);
  text-transform: uppercase;
  margin-bottom: 10px;
}
.clase-cta h2 span { color: var(--accent); }
.clase-cta p { color: var(--muted); margin-bottom: 24px; font-size: 16px; }
.btn-row {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 900px) {
  .info-grid { grid-template-columns: 1fr; }
  .otras-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .clase-hero-icon { width: 90px; height: 90px; font-size: 42px; }
  .otras-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block page_content %}
{# ── HERO ── #}
<div class="page-hero clase-hero">
  <div class="container">
    <a href="{{ path('app_home') }}#clases" class="btn-back">&larr; Volver a clases</a>
    <div class="clase-hero-icon" data-aos="zoom-in" data-aos-duration="600">{{ clase.icono }}</div>
    <h1 data-aos="fade-up">{{ clase.nombre }}</h1>
    <p data-aos="fade-up" data-aos-delay="100">{{ clase.que_es[:120] ~ '...' }}</p>
    <div class="clase-hero-meta" data-aos="fade-up" data-aos-delay="200">
      <span>🕐 {{ clase.horario }}</span>
      <span>📍 FitLife Gym</span>
      <span>⚡ Todos los niveles</span>
    </div>
  </div>
</div>

{# ── INFORMACIÓN DETALLADA ── #}
<section class="content-section">
  <div class="info-grid">
    <div class="info-card" data-aos="fade-up" data-aos-delay="0">
      <div class="card-icon">📝</div>
      <h3>Que es</h3>
      <p>{{ clase.que_es }}</p>
    </div>

    <div class="info-card" data-aos="fade-up" data-aos-delay="100">
      <div class="card-icon">🎯</div>
      <h3>Que incluye</h3>
      <p>{{ clase.actividades }}</p>
    </div>

    <div class="info-card" data-aos="fade-up" data-aos-delay="200">
      <div class="card-icon">✨</div>
      <h3>Beneficios</h3>
      <p>{{ clase.beneficios }}</p>
    </div>
  </div>

  {# ── OTRAS CLASES ── #}
  <div style="margin-top: 80px;">
    <div class="section-tag">Explora mas</div>
    <h2 class="section-title">Otras Clases</h2>
    <div class="otras-grid">
      {% for otra in otrasClases %}
      <a href="{{ path('app_clase_detalle', { slug: otra.slug }) }}" class="otra-card" data-aos="fade-up" data-aos-delay="{{ loop.index * 60 }}">
        <span class="mini-icon">{{ otra.icono }}</span>
        <div class="info">
          <div class="name">{{ otra.nombre }}</div>
          <div class="horario">{{ otra.horario }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>

  {# ── CTA ── #}
  <div class="clase-cta" data-aos="fade-up">
    <h2>Listo para probar <span>{{ clase.nombre }}</span>?</h2>
    <p>Visitanos y prueba tu primera clase gratis. Sin compromiso.</p>
    <div class="btn-row">
      <a href="{{ path('app_ubicacion') }}" class="btn-primary">Registrate Gratis &rarr;</a>
      <a href="{{ path('app_home') }}#precios" class="btn-outline">Ver Planes</a>
    </div>
  </div>
</section>
{% endblock %}