{# templates/home/index.html.twig — Página principal (informativa) #}
{% extends 'layouts/public.html.twig' %}

{% block title %}FitLife — Tu Gimnasio de Alto Rendimiento{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ── HERO ── */
.hero {
  min-height: 100vh;
  padding-top: 76px;
  background: linear-gradient(135deg, rgba(0,0,0,0.88) 0%, rgba(18,8,0,0.82) 100%),
              url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
  background-size: 150% auto;
  background-position: center 30%;
  background-attachment: fixed;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 40%, rgba(255,234,0,.10) 0%, transparent 70%);
  z-index: 1;
  pointer-events: none;
}
.hero-content {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 60px;
  position: relative;
  z-index: 2;
  text-align: center;
  width: 100%;
}
.hero-eyebrow {
  display: inline-block;
  background: rgba(255,234,0,.14);
  color: var(--accent);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 4px;
  padding: 8px 24px;
  border-radius: 50px;
  margin-bottom: 24px;
  text-transform: uppercase;
}
.hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(60px, 8.5vw, 120px);
  line-height: 0.9;
  letter-spacing: -2px;
  margin-bottom: 24px;
  text-transform: uppercase;
}
.hero h1 span { color: var(--accent); }
.hero p {
  font-size: 19px;
  color: var(--muted);
  max-width: 600px;
  margin: 0 auto 44px;
  line-height: 1.5;
}
.hero-btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

/* ── CLASES ── */
.clases-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 20px;
  margin-top: 48px;
}
.clase-card {
  background: var(--card);
  border-radius: 20px;
  padding: 28px 16px;
  text-align: center;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid var(--border);
  cursor: pointer;
  text-decoration: none;
  color: var(--text);
  display: block;
}
.clase-card:hover {
  transform: translateY(-10px);
  border-color: var(--accent);
  box-shadow: 0 20px 40px rgba(255,234,0,.12);
}
.clase-icon {
  width: 80px;
  height: 80px;
  background: var(--accent);
  color: #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  margin: 0 auto 20px;
  transition: transform 0.3s ease;
}
.clase-card:hover .clase-icon { transform: scale(1.12) rotate(-5deg); }
.clase-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.clase-horario {
  color: var(--muted);
  font-size: 13px;
  font-weight: 500;
}

/* ── CARRUSEL DE PLANES ── */
.carrusel-container {
  margin-top: 48px;
  position: relative;
  width: 100%;
}
.carrusel-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  gap: 24px;
  padding: 16px 8px 36px;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}
.carrusel-track::-webkit-scrollbar { height: 5px; }
.carrusel-track::-webkit-scrollbar-track { background: #1a1a1a; border-radius: 10px; }
.carrusel-track::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 10px; }

.precio-card {
  flex: 0 0 320px;
  scroll-snap-align: start;
  background: var(--accent);
  color: #000;
  border-radius: 22px;
  padding: 40px 28px;
  transition: all 0.3s ease;
  box-shadow: 0 12px 36px rgba(0,0,0,.25);
  text-decoration: none;
  display: block;
}
.precio-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 50px rgba(255,234,0,.25);
}
.precio-card.destacado {
  border: 4px solid #000;
  transform: scale(1.03);
}
.precio-card.destacado:hover {
  transform: scale(1.03) translateY(-8px);
}

.carrusel-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.75);
  border: 1px solid var(--accent);
  color: var(--accent);
  font-size: 24px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  cursor: pointer;
  z-index: 2;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.carrusel-btn:hover { background: var(--accent); color: #000; }
.carrusel-btn.left { left: -14px; }
.carrusel-btn.right { right: -14px; }

.precio-nombre {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.precio-monto {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 64px;
  line-height: 1;
  margin-bottom: 4px;
}
.precio-period {
  font-size: 16px;
  font-weight: 600;
  opacity: 0.85;
}
.precio-features {
  list-style: none;
  margin: 32px 0;
}
.precio-features li {
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,.12);
  font-size: 15px;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10px;
}
.precio-features li::before {
  content: "✓";
  font-weight: 900;
}
.btn-plan {
  display: block;
  width: 100%;
  text-align: center;
  padding: 16px;
  background: #000;
  color: var(--accent);
  border-radius: 50px;
  font-weight: 700;
  font-size: 16px;
  text-transform: uppercase;
  text-decoration: none;
  margin-top: 16px;
  transition: all 0.3s ease;
}
.btn-plan:hover { background: #111; }

/* ── MÁQUINAS PREVIEW ── */
.maquinas-preview {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
  margin-top: 48px;
}
.maquina-card-sm {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
  transition: all 0.3s ease;
}
.maquina-card-sm:hover {
  transform: translateY(-5px);
  border-color: rgba(255,234,0,.25);
  box-shadow: 0 12px 28px rgba(0,0,0,.25);
}
.maquina-card-sm .icon { font-size: 40px; margin-bottom: 12px; }
.maquina-card-sm .name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  margin-bottom: 8px;
}
.maquina-card-sm .desc { color: var(--muted); font-size: 14px; line-height: 1.5; }

.ver-todas-wrap {
  text-align: center;
  margin-top: 36px;
}

/* ── CTA FINAL ── */
.cta-section {
  background: linear-gradient(135deg, #0f0f0f, #000000);
  padding: 120px 60px;
  text-align: center;
}
.cta-section h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 7vw, 84px);
  line-height: 1;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.cta-section h2 span { color: var(--accent); }
.cta-section p {
  font-size: 20px;
  color: var(--muted);
  max-width: 600px;
  margin: 0 auto 40px;
}

/* ── RESPONSIVE HOME ── */
@media (max-width: 900px) {
  .hero-content { padding: 0 20px; }
  .precio-card { flex: 0 0 270px; padding: 32px 22px; }
  .carrusel-btn { width: 36px; height: 36px; font-size: 20px; }
  .carrusel-btn.left { left: -8px; }
  .carrusel-btn.right { right: -8px; }
  .cta-section { padding: 80px 20px; }
}
@media (max-width: 480px) {
  .clases-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .clase-card { padding: 20px 10px; }
  .clase-icon { width: 64px; height: 64px; font-size: 28px; }
  .precio-card { flex: 0 0 250px; }
}
</style>
{% endblock %}

{% block page_content %}
{# ── HERO ── #}
<section class="hero">
  <div class="hero-content" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="200">
    <span class="hero-eyebrow">Gimnasio N.1 de la Ciudad</span>
    <h1>Rompe tus <span>Limites.</span></h1>
    <p>Entrenamiento de elite, instructores certificados y la comunidad mas motivada. Tu transformacion empieza hoy.</p>
    <div class="hero-btns">
      <a href="#precios" class="btn-primary">Ver Planes &rarr;</a>
      <a href="#clases" class="btn-outline">Nuestras Clases</a>
    </div>
  </div>
</section>

{# ── CLASES ── #}
<section class="content-section" id="clases">
  <div class="section-tag" data-aos="fade-right">Actividades</div>
  <h2 class="section-title" data-aos="fade-right" data-aos-delay="100">Nuestras Clases</h2>
  <p class="section-sub" data-aos="fade-right" data-aos-delay="200">Programas disenados para todos los niveles. Desde principiantes hasta atletas avanzados.</p>

  <div class="clases-grid">
    {% for clase in clases %}
    <a href="{{ path('app_clase_detalle', { slug: clase.slug }) }}" class="clase-card" data-aos="zoom-in" data-aos-duration="500" data-aos-delay="{{ loop.index * 80 }}">
      <div class="clase-icon">{{ clase.icono }}</div>
      <div class="clase-name">{{ clase.nombre }}</div>
      <div class="clase-horario">{{ clase.horario }}</div>
    </a>
    {% endfor %}
  </div>
</section>

{# ── PLANES (CARRUSEL) ── #}
<section class="content-section" id="precios">
  <div class="section-tag" data-aos="fade-right">Membresias</div>
  <h2 class="section-title" data-aos="fade-right" data-aos-delay="100">Elige tu Plan</h2>
  <p class="section-sub" data-aos="fade-right" data-aos-delay="200">Sin contratos a largo plazo. Cancela cuando quieras. Resultados garantizados.</p>

  <div class="carrusel-container">
    <div class="carrusel-track" id="planTrack">
      {% for plan in planes %}
      <a href="{{ path('app_ubicacion') }}" class="precio-card {{ plan.destacado ? 'destacado' : '' }}" data-aos="flip-up" data-aos-duration="700" data-aos-delay="{{ loop.index * 80 }}">
        <div class="precio-nombre">{{ plan.nombre }}</div>
        <div class="precio-monto">bs {{ plan.precio }}</div>
        <div class="precio-period">por {{ plan.duracion }}</div>
        <ul class="precio-features">
          {% for f in plan.features %}
            <li>{{ f }}</li>
          {% endfor %}
        </ul>
        <span class="btn-plan">Comenzar Ahora</span>
      </a>
      {% endfor %}
    </div>
    <button class="carrusel-btn left" id="scrollLeft">&larr;</button>
    <button class="carrusel-btn right" id="scrollRight">&rarr;</button>
  </div>
</section>

{# ── MÁQUINAS (VISTA PREVIA) ── #}
<section class="content-section" id="maquinas">
  <div class="section-tag" data-aos="fade-right">Equipamiento</div>
  <h2 class="section-title" data-aos="fade-right" data-aos-delay="100">Nuestras Maquinas</h2>
  <p class="section-sub" data-aos="fade-right" data-aos-delay="200">Equipos de ultima generacion para que entrenes con seguridad y efectividad.</p>

  <div class="maquinas-preview">
    {% for m in maquinas %}
    <div class="maquina-card-sm" data-aos="fade-up" data-aos-delay="{{ loop.index * 60 }}">
      <div class="icon">{{ m.icono }}</div>
      <div class="name">{{ m.nombre }}</div>
      <div class="desc">{{ m.descripcion }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="ver-todas-wrap" data-aos="fade-up" data-aos-delay="300">
    <a href="{{ path('app_maquinas') }}" class="btn-outline">Ver todas las maquinas &rarr;</a>
  </div>
</section>

{# ── CTA FINAL ── #}
<div class="cta-section">
  <h2 data-aos="fade-up">El momento es <span>AHORA.</span></h2>
  <p data-aos="fade-up" data-aos-delay="100">Primera semana gratis para nuevos miembros. Sin excusas.</p>
  <a href="{{ path('app_ubicacion') }}" class="btn-primary" data-aos="fade-up" data-aos-delay="200">Registrate Gratis &rarr;</a>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
  /* Carrusel de planes */
  const track = document.getElementById('planTrack');
  const leftBtn = document.getElementById('scrollLeft');
  const rightBtn = document.getElementById('scrollRight');

  if (track && leftBtn && rightBtn) {
    leftBtn.addEventListener('click', () => track.scrollBy({ left: -340, behavior: 'smooth' }));
    rightBtn.addEventListener('click', () => track.scrollBy({ left: 340, behavior: 'smooth' }));
  }
</script>
{% endblock %}