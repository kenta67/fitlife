{# templates/home/maquinas.html.twig — Catálogo completo de máquinas #}
{% extends 'layouts/public.html.twig' %}

{% block title %}Maquinas — FitLife Gym{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.maquinas-hero {
  background: linear-gradient(135deg, #0a0a0a 0%, #0a100a 50%, #0a0a0a 100%);
}

/* ── FILTROS ── */
.filtros {
  display: flex;
  gap: 12px;
  margin-top: 36px;
  flex-wrap: wrap;
}
.filtro-btn {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--muted);
  padding: 10px 24px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
  font-family: inherit;
}
.filtro-btn:hover {
  border-color: rgba(255,234,0,.3);
  color: var(--text);
}
.filtro-btn.active {
  background: var(--accent);
  color: #000;
  border-color: var(--accent);
}

/* ── GRID DE MÁQUINAS ── */
.maquinas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 24px;
  margin-top: 40px;
}
.maquina-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 0;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.maquina-card:hover {
  transform: translateY(-6px);
  border-color: rgba(255,234,0,.3);
  box-shadow: 0 20px 48px rgba(0,0,0,.35);
}
.maquina-card.hidden {
  display: none;
}

.maquina-top {
  padding: 28px 28px 0;
  display: flex;
  align-items: flex-start;
  gap: 18px;
}
.maquina-icon-wrap {
  width: 64px;
  height: 64px;
  background: rgba(255,234,0,.08);
  border: 1px solid rgba(255,234,0,.12);
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  flex-shrink: 0;
}
.maquina-top-text .nombre {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px;
  letter-spacing: 0.5px;
}
.maquina-top-text .cat-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  padding: 3px 10px;
  border-radius: 20px;
  margin-top: 4px;
}
.cat-badge.cardio { background: rgba(63,185,80,.12); color: #3fb950; }
.cat-badge.fuerza { background: rgba(88,166,255,.12); color: #58a6ff; }
.cat-badge.libre { background: rgba(188,140,255,.12); color: #bc8cff; }

.maquina-body {
  padding: 20px 28px 28px;
}
.maquina-body .desc {
  color: var(--muted);
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 20px;
}
.maquina-detail {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.maquina-detail-row {
  background: rgba(255,255,255,.02);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
}
.maquina-detail-row .label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--accent);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.maquina-detail-row .text {
  color: rgba(255,255,255,.75);
  font-size: 14px;
  line-height: 1.6;
}

/* ── RESUMEN ── */
.resumen-bar {
  display: flex;
  gap: 20px;
  margin-top: 60px;
  flex-wrap: wrap;
}
.resumen-item {
  flex: 1;
  min-width: 160px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
  text-align: center;
}
.resumen-item .val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 42px;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 4px;
}
.resumen-item .lbl {
  font-size: 13px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
}

/* ── CTA ── */
.maquinas-cta {
  text-align: center;
  margin-top: 60px;
  padding: 60px 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 24px;
}
.maquinas-cta h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(32px, 4vw, 48px);
  text-transform: uppercase;
  margin-bottom: 10px;
}
.maquinas-cta h2 span { color: var(--accent); }
.maquinas-cta p { color: var(--muted); margin-bottom: 24px; }

@media (max-width: 600px) {
  .maquinas-grid { grid-template-columns: 1fr; }
  .maquina-top { padding: 20px 20px 0; }
  .maquina-body { padding: 16px 20px 20px; }
}
</style>
{% endblock %}

{% block page_content %}
{# ── HERO ── #}
<div class="page-hero maquinas-hero">
  <div class="container">
    <a href="{{ path('app_home') }}" class="btn-back">&larr; Volver al inicio</a>
    <span class="page-tag">Equipamiento</span>
    <h1 data-aos="fade-up">Nuestras Maquinas</h1>
    <p data-aos="fade-up" data-aos-delay="100">Catalogo completo de equipos de ultima generacion disponibles en nuestro gimnasio.</p>
  </div>
</div>

{# ── CONTENIDO ── #}
<section class="content-section">
  {# ── FILTROS ── #}
  <div class="filtros" data-aos="fade-up">
    <button class="filtro-btn active" data-filtro="todas">Todas ({{ maquinas|length }})</button>
    <button class="filtro-btn" data-filtro="cardio">Cardio</button>
    <button class="filtro-btn" data-filtro="fuerza">Fuerza</button>
    <button class="filtro-btn" data-filtro="libre">Libre</button>
  </div>

  {# ── GRID ── #}
  <div class="maquinas-grid" id="maquinasGrid">
    {% for m in maquinas %}
    <div class="maquina-card" data-categoria="{{ m.categoria }}" data-aos="fade-up" data-aos-delay="{{ loop.index * 50 }}">
      <div class="maquina-top">
        <div class="maquina-icon-wrap">{{ m.icono }}</div>
        <div class="maquina-top-text">
          <div class="nombre">{{ m.nombre }}</div>
          <span class="cat-badge {{ m.categoria }}">{{ m.categoria }}</span>
        </div>
      </div>
      <div class="maquina-body">
        <p class="desc">{{ m.descripcion }}</p>
        <div class="maquina-detail">
          <div class="maquina-detail-row">
            <div class="label">🔧 Para que sirve</div>
            <div class="text">{{ m.para_que }}</div>
          </div>
          <div class="maquina-detail-row">
            <div class="label">⭐ Beneficios</div>
            <div class="text">{{ m.beneficios }}</div>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  {# ── RESUMEN ── #}
  <div class="resumen-bar" data-aos="fade-up" data-aos-delay="100">
    <div class="resumen-item">
      <div class="val">{{ maquinas|length }}</div>
      <div class="lbl">Maquinas</div>
    </div>
    <div class="resumen-item">
      <div class="val">{{ maquinas|filter(m => m.categoria == 'cardio')|length }}</div>
      <div class="lbl">Cardio</div>
    </div>
    <div class="resumen-item">
      <div class="val">{{ maquinas|filter(m => m.categoria == 'fuerza')|length }}</div>
      <div class="lbl">Fuerza</div>
    </div>
    <div class="resumen-item">
      <div class="val">{{ maquinas|filter(m => m.categoria == 'libre')|length }}</div>
      <div class="lbl">Libre</div>
    </div>
  </div>

  {# ── CTA ── #}
  <div class="maquinas-cta" data-aos="fade-up">
    <h2>Entrena con lo <span>Mejor</span></h2>
    <p>Nuestro equipamiento esta listo para ti. Visitanos y compruebalo por ti mismo.</p>
    <a href="{{ path('app_ubicacion') }}" class="btn-primary">Registrate Gratis &rarr;</a>
  </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
  /* Filtro de máquinas por categoría */
  const filtroBtns = document.querySelectorAll('.filtro-btn');
  const maquinaCards = document.querySelectorAll('.maquina-card');

  filtroBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filtroBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filtro = btn.dataset.filtro;

      maquinaCards.forEach(card => {
        if (filtro === 'todas' || card.dataset.categoria === filtro) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
{% endblock %}