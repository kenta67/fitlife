  <button class="menu-toggle" id="menuToggle" aria-label="Menú">
    <span></span><span></span><span></span>
  </button>
</nav>

{# ── CONTENIDO DE CADA PÁGINA ── #}
{% block page_content %}{% endblock %}

{# ── FOOTER ── #}
<footer>
  <div class="footer-inner">
